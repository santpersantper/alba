{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "credentialsSource": "local",
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "npx expo prebuild --clean",
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.1"
      }
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "npx expo prebuild --clean",
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.1"
      }
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "npx expo prebuild --clean",
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}